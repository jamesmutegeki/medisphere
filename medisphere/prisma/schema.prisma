generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
  NURSE
  ADMIN
  BILLING
  SUPER_ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum WardType {
  EMERGENCY
  ICU
  GENERAL
  PEDIATRICS
  MATERNITY
  SURGERY
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  PARTIAL
  CANCELLED
  INSURANCE_PENDING
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  DENIED
  PAID
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role      @default(PATIENT)
  phone          String?
  avatarUrl      String?
  dateOfBirth    DateTime?
  address        String?
  isActive       Boolean   @default(true)
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  patientProfile      PatientProfile?
  doctorProfile       DoctorProfile?
  adminProfile        AdminProfile?
  appointments        Appointment[]    @relation("PatientAppointments")
  doctorAppointments  Appointment[]    @relation("DoctorAppointments")
  medicalRecordsAsPatient MedicalRecord[] @relation("PatientMedicalRecords")
  medicalRecordsAsDoctor  MedicalRecord[] @relation("DoctorMedicalRecords")
  prescriptionsAsPatient Prescription[]  @relation("PatientPrescriptions")
  prescriptionsAsDoctor  Prescription[]  @relation("DoctorPrescriptions")
  vitalRecordsAsPatient  VitalRecord[]   @relation("PatientVitals")
  vitalRecordsAsRecordedBy VitalRecord[]  @relation("RecordedByVitals")
  auditLogs           AuditLog[] @relation("UserAuditLogs")
  shifts              StaffShift[]
  invoices            Invoice[]        @relation("PatientInvoices")
  createdInvoices     Invoice[]        @relation("BillingOfficerInvoices")
  insuranceClaims     InsuranceClaim[] @relation("PatientClaims")
  processedClaims     InsuranceClaim[] @relation("ProcessorClaims")
  labResultsAsPatient LabResult[]      @relation("PatientLabResults")
  labResultsAsDoctor  LabResult[]      @relation("DoctorLabResults")
  dispensingsAsPatient DispensingLog[] @relation("PatientDispensings")
  dispensingsAsDispenser DispensingLog[] @relation("DispenserLogs")
  immunizationsAsPatient Immunization[] @relation("PatientImmunizations")
  immunizationsAsProvider Immunization[] @relation("ProviderImmunizations")
  referralsAsPatient  Referral[]       @relation("PatientReferrals")
  referralsAsReferringDoctor Referral[] @relation("ReferringDoctor")
  referralsAsReferredDoctor Referral[]  @relation("ReferredDoctor")
  beds                Bed[]
  leaveRequests       LeaveRequest[]   @relation("StaffLeaveRequests")
  approvedLeaves      LeaveRequest[]   @relation("LeaveApprover")
  availabilities      Availability[]
  waitlistEntries     WaitlistEntry[]
  intakesAsPatient    Intake[]         @relation("PatientIntakes")
  intakesAsChecker    Intake[]         @relation("IntakeCheckers")
  notifications       Notification[]

  @@map("users")
}

model PatientProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  bloodType     String?
  allergies     String?
  emergencyContactName   String?
  emergencyContactPhone  String?
  insuranceProvider      String?
  insurancePolicyNumber  String?
  medicalHistory         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_profiles")
}

model DoctorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  licenseNumber   String   @unique
  specialization  String
  department      String
  consultationFee Decimal  @default(0)
  availableDays   String?
  availableSlots  String?
  bio             String?
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("doctor_profiles")
}

model AdminProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  department String
  staffId    String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  date            DateTime
  startTime       DateTime
  endTime         DateTime?
  status          AppointmentStatus @default(SCHEDULED)
  type            String?
  notes           String?
  cancellationReason String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient       User           @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor        User           @relation("DoctorAppointments", fields: [doctorId], references: [id])
  medicalRecords MedicalRecord[]
  @@map("appointments")
}

model MedicalRecord {
  id          String   @id @default(cuid())
  patientId   String
  doctorId    String
  appointmentId String?
  diagnosis   String?
  symptoms    String?
  treatment   String?
  notes       String?
  recordDate  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient      User           @relation("PatientMedicalRecords", fields: [patientId], references: [id])
  doctor       User           @relation("DoctorMedicalRecords", fields: [doctorId], references: [id])
  appointment  Appointment?   @relation(fields: [appointmentId], references: [id])
  prescriptions Prescription[]

  @@map("medical_records")
}

model Prescription {
  id             String   @id @default(cuid())
  medicalRecordId String?
  patientId      String
  doctorId       String
  medication     String
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  isActive       Boolean  @default(true)
  refills        Int      @default(0)
  prescribedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  medicalRecord MedicalRecord? @relation(fields: [medicalRecordId], references: [id])
  patient       User           @relation("PatientPrescriptions", fields: [patientId], references: [id])
  doctor        User           @relation("DoctorPrescriptions", fields: [doctorId], references: [id])

  @@map("prescriptions")
}

model VitalRecord {
  id          String   @id @default(cuid())
  patientId   String
  recordedBy  String
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  heartRate    Int?
  temperature  Decimal?
  respiratoryRate Int?
  oxygenSaturation Int?
  weight       Decimal?
  height       Decimal?
  notes        String?
  recordedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  patient    User @relation("PatientVitals", fields: [patientId], references: [id])
  recordedByUser User @relation("RecordedByVitals", fields: [recordedBy], references: [id])

  @@map("vital_records")
}

model Ward {
  id        String   @id @default(cuid())
  name      String
  type      WardType @default(GENERAL)
  floor     Int?
  wing      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  beds Bed[]

  @@map("wards")
}

model Bed {
  id       String    @id @default(cuid())
  wardId   String
  bedLabel String
  status   BedStatus @default(AVAILABLE)
  patientId String?
  assignedAt DateTime?

  ward    Ward   @relation(fields: [wardId], references: [id])
  patient User?  @relation(fields: [patientId], references: [id])

  @@map("beds")
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  patientId      String
  issuedBy       String
  consultationFee  Decimal     @default(0)
  labFees        Decimal       @default(0)
  medicationFees Decimal       @default(0)
  wardCharges    Decimal       @default(0)
  otherCharges   Decimal       @default(0)
  discount       Decimal       @default(0)
  tax            Decimal       @default(0)
  totalAmount    Decimal
  paidAmount     Decimal       @default(0)
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  patient         User            @relation("PatientInvoices", fields: [patientId], references: [id])
  billingOfficer  User            @relation("BillingOfficerInvoices", fields: [issuedBy], references: [id])
  insuranceClaims InsuranceClaim[] @relation("ClaimInvoice")

  @@map("invoices")
}

model InsuranceClaim {
  id            String       @id @default(cuid())
  invoiceId     String?
  patientId     String
  processedBy   String?
  providerName  String
  policyNumber  String
  claimAmount   Decimal
  approvedAmount Decimal?
  status        ClaimStatus  @default(DRAFT)
  submittedAt   DateTime?
  decisionDate  DateTime?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  invoice   Invoice? @relation("ClaimInvoice", fields: [invoiceId], references: [id])
  patient   User     @relation("PatientClaims", fields: [patientId], references: [id])
  processor User?    @relation("ProcessorClaims", fields: [processedBy], references: [id])

  @@map("insurance_claims")
}

model StaffShift {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  startTime DateTime
  endTime   DateTime
  role      Role
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("staff_shifts")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation("UserAuditLogs", fields: [userId], references: [id])

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model LabResult {
  id            String   @id @default(cuid())
  patientId     String
  doctorId      String
  testName      String
  testCategory  String
  result        String
  normalRange   String?
  unit          String?
  status        String   @default("PENDING")
  notes         String?
  performedAt   DateTime @default(now())
  resultDate    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient User @relation("PatientLabResults", fields: [patientId], references: [id])
  doctor  User @relation("DoctorLabResults", fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@map("lab_results")
}

model PharmacyItem {
  id             String   @id @default(cuid())
  medicationName String
  genericName    String?
  category       String
  stockQuantity  Int      @default(0)
  unit           String   @default("tablet")
  reorderLevel   Int      @default(10)
  unitPrice      Decimal  @default(0)
  expiryDate     DateTime?
  supplier       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  dispensingLogs DispensingLog[]

  @@index([category])
  @@map("pharmacy_items")
}

model DispensingLog {
  id              String   @id @default(cuid())
  pharmacyItemId  String
  prescriptionId  String?
  patientId       String
  dispensedBy     String
  quantity        Int
  batchNumber     String?
  notes           String?
  dispensedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  item     PharmacyItem @relation(fields: [pharmacyItemId], references: [id])
  patient  User         @relation("PatientDispensings", fields: [patientId], references: [id])
  dispenser User        @relation("DispenserLogs", fields: [dispensedBy], references: [id])

  @@map("dispensing_logs")
}

model Immunization {
  id               String   @id @default(cuid())
  patientId        String
  administeredBy   String
  vaccineName      String
  batchNumber      String?
  doseNumber       Int      @default(1)
  administrationDate DateTime @default(now())
  nextDoseDate     DateTime?
  site             String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient  User @relation("PatientImmunizations", fields: [patientId], references: [id])
  provider User @relation("ProviderImmunizations", fields: [administeredBy], references: [id])

  @@index([patientId])
  @@map("immunizations")
}

model Referral {
  id               String   @id @default(cuid())
  patientId        String
  referringDoctorId String
  referredDoctorId  String?
  department       String
  priority         String   @default("NORMAL")
  reason           String
  notes            String?
  status           String   @default("PENDING")
  responseDate     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient        User @relation("PatientReferrals", fields: [patientId], references: [id])
  referringDoctor User @relation("ReferringDoctor", fields: [referringDoctorId], references: [id])
  referredDoctor User? @relation("ReferredDoctor", fields: [referredDoctorId], references: [id])

  @@index([patientId])
  @@index([status])
  @@map("referrals")
}

model LeaveRequest {
  id         String   @id @default(cuid())
  userId     String
  startDate  DateTime
  endDate    DateTime
  type       String   @default("ANNUAL")
  reason     String?
  status     String   @default("PENDING")
  approvedBy String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User  @relation("StaffLeaveRequests", fields: [userId], references: [id])
  approver User? @relation("LeaveApprover", fields: [approvedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@map("leave_requests")
}

model InventoryItem {
  id            String   @id @default(cuid())
  itemName      String
  category      String
  quantity      Int      @default(0)
  unit          String   @default("piece")
  reorderLevel  Int      @default(5)
  unitPrice     Decimal  @default(0)
  supplier      String?
  location      String?
  expiryDate    DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([quantity])
  @@map("inventory_items")
}

model Availability {
  id          String   @id @default(cuid())
  doctorId    String
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctor User @relation(fields: [doctorId], references: [id])

  @@index([doctorId, date])
  @@map("availabilities")
}

model WaitlistEntry {
  id            String   @id @default(cuid())
  patientId     String
  department    String
  priority      String   @default("NORMAL")
  estimatedWait Int?
  checkInTime   DateTime @default(now())
  status        String   @default("WAITING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient User @relation(fields: [patientId], references: [id])

  @@index([department, status])
  @@map("waitlist_entries")
}

model Intake {
  id                      String   @id @default(cuid())
  patientId               String
  chiefComplaint          String
  bloodPressureSystolic   Int?
  bloodPressureDiastolic  Int?
  heartRate               Int?
  temperature             Decimal?
  allergies               String[]
  consent                 Boolean
  status                  String   @default("CHECKED_IN")
  checkedInBy             String
  checkInTime             DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  patient        User @relation("PatientIntakes", fields: [patientId], references: [id])
  checkedInByUser User @relation("IntakeCheckers", fields: [checkedInBy], references: [id])

  @@map("intakes")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@map("sessions")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  description String?
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
