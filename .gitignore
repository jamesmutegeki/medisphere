# Secrets and keys — never commit these
*.key
*.pem
*.priv
*.secret
*.env

# Local databases
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal

# Local client storage (encrypted stores, configs)
local_storage/
client_data/
*.localstorage

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
.env/

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Uploaded encrypted files (server temp storage)
uploads/*
!uploads/.gitkeep

# Distribution / build
dist/
build/
*.egg-info/

# OS cruft
.DS_Store
Thumbs.db

# Environment
.env

# Source PDF (design doc, not code)
*.pdf

